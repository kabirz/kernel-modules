# Top-level Kbuild — lists every module directory in this project.
# Each "obj-m += <name>/" line makes kbuild descend into <name>/ and build the
# module(s) declared by that directory's own Kbuild.
#
# To add a new module:
#   1. create <name>/ with its sources + a per-module Kbuild (obj-m += <name>.o)
#   2. add one line here: obj-m += <name>/

obj-m += test_mod/
obj-m += hello/
obj-m += cdev/
obj-m += kobject/
obj-m += sample/
obj-m += multi/
obj-m += proc/
obj-m += random/
obj-m += schedule/
obj-m += signal/
obj-m += misc/
obj-m += block/
obj-m += net/
obj-m += usb/
obj-m += input/
obj-m += gpio/
obj-m += irq/
obj-m += thread/
obj-m += lock/
obj-m += mmap/
obj-m += netlink/
obj-m += sysfs/
obj-m += platform/
obj-m += test/
